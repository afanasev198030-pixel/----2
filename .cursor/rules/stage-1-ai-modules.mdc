    "severity": "high",
    "recommendation": "Цена на {diff_percent}% ниже медианы. Риск корректировки таможенной стоимости. Приложите прайс-лист и коммерческое предложение."
  },
  {
    "code": "WEIGHT_RATIO",
    "name": "Превышение брутто над нетто >20%",
    "conditions": {
      "field": "gross_weight / net_weight",
      "operator": "greater_than",
      "value": 1.2
    },
    "severity": "medium",
    "recommendation": "Отношение брутто/нетто = {ratio}. Норма до 1.2. Проверьте данные упаковочных листов."
  },
  {
    "code": "NEW_COUNTERPARTY",
    "name": "Новый контрагент",
    "conditions": {
      "field": "counterparty_age_days",
      "operator": "less_than",
      "value": 30
    },
    "severity": "medium",
    "recommendation": "Контрагент новый (<30 дней). Запросите дополнительные реквизиты и сертификат регистрации."
  },
  {
    "code": "MISSING_CERTIFICATE",
    "name": "Отсутствует обязательный сертификат",
    "conditions": {
      "field": "hs_code",
      "operator": "requires_document",
      "document_type": "certificate_origin"
    },
    "severity": "critical",
