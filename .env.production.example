# =============================================================================
# Production Environment — Digital Broker Platform
# =============================================================================
# Скопируйте этот файл в .env на production-сервере и заполните все значения.
# Сервисы НЕ запустятся если обязательные переменные не заданы.
#
# Генерация секретов:
#   openssl rand -hex 16   — для паролей (32 символа)
#   openssl rand -hex 32   — для JWT ключа (64 символа)
# =============================================================================

# --- PostgreSQL (ОБЯЗАТЕЛЬНО) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=customs
POSTGRES_USER=customs_user
POSTGRES_PASSWORD=              # openssl rand -hex 16

# --- Redis (ОБЯЗАТЕЛЬНО) ---
REDIS_PASSWORD=                 # openssl rand -hex 16

# --- MinIO / S3 (ОБЯЗАТЕЛЬНО) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=               # придумайте username (минимум 3 символа)
MINIO_SECRET_KEY=               # openssl rand -hex 16
MINIO_BUCKET=documents
MINIO_SECURE=false

# --- JWT (ОБЯЗАТЕЛЬНО) ---
JWT_SECRET_KEY=                 # openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# --- Logging ---
LOG_LEVEL=INFO

# --- LLM Provider (ОБЯЗАТЕЛЬНО для AI) ---
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=                    # API-ключ провайдера
LLM_MODEL=deepseek-chat
LLM_REASONING_MODEL=deepseek-reasoner
EMBED_PROVIDER=local

# --- Vision OCR (опционально) ---
# OCR_ENABLED=true
# OCR_BASE_URL=https://foundation-models.api.cloud.ru/v1
# OCR_API_KEY=                  # API-ключ Cloud.ru
# OCR_MODEL=deepseek-ai/DeepSeek-OCR-2
# OCR_PROJECT_ID=

# --- Legacy OpenAI (опционально, fallback) ---
# OPENAI_API_KEY=               # sk-... ключ OpenAI
# OPENAI_MODEL=gpt-4o

# --- Telegram Bot (опционально) ---
# TELEGRAM_BOT_TOKEN=           # токен от @BotFather
# TELEGRAM_BOT_USERNAME=DigitalBrokerBot
