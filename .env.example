# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=customs
POSTGRES_USER=customs_user
POSTGRES_PASSWORD=customs_pass

# Redis
REDIS_URL=redis://redis:6379/0
# REDIS_PASSWORD=               # пусто для dev, обязательно для prod

# MinIO (S3)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=false

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Service Ports
CORE_API_PORT=8001
FILE_SERVICE_PORT=8002

# Logging
LOG_LEVEL=DEBUG

# LLM Provider (DeepSeek default — cheaper, faster)
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-deepseek-key
LLM_MODEL=deepseek-chat
LLM_REASONING_MODEL=deepseek-reasoner
EMBED_PROVIDER=local

# Cloud.ru Foundation Models (alternative — uncomment to use)
# LLM_PROVIDER=cloud_ru
# LLM_BASE_URL=https://foundation-models.api.cloud.ru/v1
# LLM_API_KEY=your-cloud-ru-bearer-token
# LLM_MODEL=openai/gpt-oss-120b
# LLM_PROJECT_ID=your-project-id

# Vision OCR (DeepSeek-OCR-2 via Cloud.ru — replaces Tesseract/pdfplumber)
# OCR_ENABLED=true
# OCR_BASE_URL=https://foundation-models.api.cloud.ru/v1
# OCR_API_KEY=your-cloud-ru-bearer-token
# OCR_MODEL=deepseek-ai/DeepSeek-OCR-2
# OCR_PROJECT_ID=your-project-id

# Legacy OpenAI (still supported as fallback)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ChromaDB (Phase 2)
CHROMADB_HOST=localhost
CHROMADB_PORT=8100

# Phoenix (observability)
PHOENIX_HOST=localhost
PHOENIX_PORT=6006

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=YourBrokerBot
